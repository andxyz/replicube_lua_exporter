## Test data
*_test_*/

#####
## GOLANG GITIGNORE
#####
# sample progress files
replicube_lua_exporter_golang/*_progress.dat
# the executable
replicube_lua_exporter_golang/replicube_lua_exporter
# tmp dirs
replicube_lua_exporter_golang/replicube_solutions*/*

#####
## RUST GITIGNORE
#####
# sample progress files
replicube_lua_exporter_rust/*_progress.dat
# tmp dirs
replicube_lua_exporter_rust/replicube_solutions*/*
# Generated by Cargo
# will have compiled files and executables
replicube_lua_exporter_rust/debug
replicube_lua_exporter_rust/target
# These are backup files generated by rustfmt
replicube_lua_exporter_rust/**/*.rs.bk
# MSVC Windows builds of rustc generate these, which store debugging information
replicube_lua_exporter_rust/*.pdb
# Generated by cargo mutants
# Contains mutation testing data
replicube_lua_exporter_rust/**/mutants.out*/

## RustRover
.idea/
## Zed
.zed/
