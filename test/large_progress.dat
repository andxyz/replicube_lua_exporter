	if x<-2 then
		local a= d*(t+5)
--		local xpx= round(x - 5*sin(5*d))
		return (x+4)*cos(a) - z*sin(a) + 2.5
	end
	local a= (t+4)*d
	return x*cos(a) - z*sin(a) + 2.5
end

if x>0 then
	local a= d*(t+2)
--	local xpx= round(x - 5*sin(2*d))
	return (x-5)*cos(a) - z*sin(a) + 2.5
end

local a= d*(t+6)
--local xpx= round(x - 5*sin(6*d))
return (x+5)*cos(a) - z*sin(a) + 2.5
