if x==-4 or z==-4 then
	local n= 10-y
	return n
end
if x==-3 or z==-3 then
	local n= 10-y
	return n*(n-1)/2
  -- if y==6 then return 6 end -- slower
  -- if y==5 then return 10 end
  -- if y==4 then return 15 end
  -- if y==3 then return 5 end
  -- if y==2 then return 12 end
