 	if (x%2==0) and (v-2)%4==0 then return LIGHTGREEN end
	return
end
local Z4_x_X4= (z%4)*(x%4)
if y==6 then
	if (Z4_x_X4==0) and ((v<=14 and v>=10) or (v<=6 and v>=2)) then 
		return GREEN
	end
	return
end
