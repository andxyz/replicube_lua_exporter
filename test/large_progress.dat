"faster": "-- LOTS OF WIND RESISTENCE.
-- REALLY BEEFS UP THE ARMS!

-- EMPTYSPACE
if z ~= 0 then return end
if x^2 > 9 then return end
-- RACQUET
if y>-2 then
	if x^2 == 9 then return RED end
	if y == -1 or y==5 then return RED end
