		or sz==0 and RED
		or sz==-1 and LIGHTGREEN
end
if y==z and y%2==0 then
	local sy= sign(y)
	return abs(y)==extent and WHITE
		or sy==1 and LIGHTBLUE
		or sy==0 and RED
		or sy==-1 and LIGHTGREEN
end
local X,Y,Z=abs(x),abs(y),abs(z)
if btoi(X==extent)+btoi(Y==extent)+btoi(Z==extent)>=2 then 
	return WHITE
end
