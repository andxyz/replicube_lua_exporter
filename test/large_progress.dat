"first_pass": "-- Angles
--phi=0.9553166   --pi/2 - arctan(1/sqrt(2)) (Rotates the cube upright)
--phi=pi/2 - atan(1/sqrt(2)) -- (Rotates the cube upright)

local xi=pi/4
local phi_z=xi
local phi_x=asin(1/sqrt(3))
local phi_y=-pi/3 - t*xi/4
local size=4.9
-- Transforms
local RZ = { -- z-axis
    { 1 ,     0     ,       0    },
    { 0 , cos(phi_z), -sin(phi_z)},
    { 0 , sin(phi_z),  cos(phi_z)}
}
local RX = { -- x-axis
    {cos(phi_x), -sin(phi_x), 0},
    {sin(phi_x),  cos(phi_x), 0},
    {     0    ,      0     , 1}
}
local RY = { -- y-axis
    {  cos(phi_y), 0 , sin(phi_y)},
    {    0       , 1 ,     0     },
    { -sin(phi_y), 0 , cos(phi_y)}
}
-- function \"f\" apply transform matrix \"R\" to a point \"p\"
local function f(R, p)
	return {
    R[1][1]*p[1] + R[1][2]*p[2] + R[1][3]*p[3],
    R[2][1]*p[1] + R[2][2]*p[2] + R[2][3]*p[3],
    R[3][1]*p[1] + R[3][2]*p[2] + R[3][3]*p[3]
	}
end
ox,oy,oz= x,y,z
-- main()
x,y,z= unpack(
	f(RZ, f(RX, f(RY, {x, y, z})))
)

if inrange(x,-size,size) and inrange(y,-size,size) and inrange(z,-size,size) then
	local c= x/1.8+10
--	if (t==4 or t==12 or t==20) and (oy<=2) and (ox<4 and oz<4) then
--		print(\"x=\"..x..\" c=\"..c)
--	end
	if oy<=-1 and c==10 and x <= 0 then return YELLOW end
  return c
end
",
"s1": "-- s1
-- 191
-- 120.780
-- setup()
-- local xi= pi/4
phi_z= pi/4
phi_x= atan(1/sqrt(2)) -- asin(1/sqrt(3))
phi_y= -pi/3 - t*phi_z/4
size= 4.9
-- main()
-- Transforms applied in order firstly y then x then z
p= { x*cos(phi_y) + z*sin(phi_y), y , -x*sin(phi_y) + z*cos(phi_y) }
p= { p[1]*cos(phi_x) - p[2]*sin(phi_x), p[1]*sin(phi_x) + p[2]*cos(phi_x) , p[3] }
p= { p[1], p[2]*cos(phi_z) - p[3]*sin(phi_z), p[2]*sin(phi_z) + p[3]*cos(phi_z) }

-- render()
if abs(p[1])<=size and abs(p[2])<=size and abs(p[3])<=size then
--	return x/1.8+10
	color= p[1]/1.8+10
--	if (t==4 or t==12 or t==20) and (y<=2) and (x<4 and z<4) then
--		print(\"x=\"..p[1]..\" c=\"..c)
--	end
	if y<=-1 and color==10 and p[1] <= 0 then -- strange exception due to rounding error
		return YELLOW
	end
  return color
end
"
