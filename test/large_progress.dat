"code": "--[[
Hi there! Thanks for trying my puzzle.

This is an execice in using Matrices to generate a 
3-Dimensional Object. We'll use the SO(3,R) group,
to ensure all the edges stay orthogonal and the volume
stays constant. I even made all the necessary math for you.
To start, try incorporating following function.

  f_phi: R^3 ---> R^3
	
           / cos(phi)   -sin(phi)   0  \\
 v |----> |  sin(phi)    cos(phi)   0   | * v
           \\    0           0       1  /

Good luck and have fun.
~ Zin
]]

phi=0.9553166   --pi/2 - arctan(1/sqrt(2)) (Rotates the cube upright)
xi=pi/4
size=4.9

if inrange(x,-size,size) and inrange(y,-size,size) and inrange(z,-size,size) then
 return x/1.8+10
end",
"f1": "-- Angles
local xi=pi/4
local phi_z=xi
local phi_x=atan(1/sqrt(2))-- asin(1/sqrt(3))
local phi_y=-pi/3 - t*xi/4
local size=4.9
-- Transforms
local function rx(p)
	return { p[1], p[2]*cos(phi_z) - p[3]*sin(phi_z), p[2]*sin(phi_z) + p[3]*cos(phi_z) }
end
local function rz(p) 
	return { p[1]*cos(phi_x)-p[2]*sin(phi_x), p[1]*sin(phi_x)+ p[2]*cos(phi_x) , p[3] }
end
local function ry(p)
	return { p[1]*cos(phi_y) + p[3]*sin(phi_y), p[2] , - p[1]*sin(phi_y) + p[3]*cos(phi_y) }
end

ox,oy,oz= x,y,z -- backup orig x,y,z
-- main()
x,y,z= unpack(
	rx(rz(ry({x, y, z})))
)

if x>=-size and x<=size and y>=-size and y<=size and z>=-size and z<=size then
--	return x/1.8+10
	local c= x/1.8+10
--	if (t==4 or t==12 or t==20) and (oy<=2) and (ox<4 and oz<4) then
--		print(\"x=\"..x..\" c=\"..c)
--	end
	if oy<=-1 and c==10 and x <= 0 then return YELLOW end
  return c
end
