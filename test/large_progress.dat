	local xpx= round(x - 5*sin(i*d))
	return xpx*cos(a) - z*sin(a) + 2.5
end
local yp4= (y+4)^2
if xm4^2+yp4+Z<= 3 then
	local i= 3
	local a= d*(t+i)
	local xpx= round(x - 5*sin(i*d))
	return xpx*cos(a) - z*sin(a) + 2.5
end
local xp4= (x+4)^2
if xp4^2+yp4^2+Z<= 3 then
	local i= 5
	local a= d*(t+i)
	local xpx= round(x - 5*sin(i*d))
	return xpx*cos(a) - z*sin(a) + 2.5
end
if xp4^2+ym4+Z<= 3 then
	local i= 7
	local a= d*(t+i)
	local xpx= round(x - 5*sin(i*d))
	return xpx*cos(a) - z*sin(a) + 2.5
end
",
