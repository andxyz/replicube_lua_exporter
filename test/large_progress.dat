-- trim negative space
if z<-1 or z>1 then return end
local circ= x^2+y^2
if circ > 50 then return end
if circ < 16 then return end
if circ == 45 then return end
if x==-2 or x==2 then return end
if y==-2 or y==2 then return end
if x>6 or x<-6 then return end
if y>6 or y<-6 then return end

-- inline all the things, try my best to not call functions, like round or ^2
-- doing bounds checks instead of squaring for the cubes
local d= pi/4

if y>2 then
	if x>2 then
		local a= d*(t+1)
--		local xpx= round(x - 5*sin(1*d))
		return (x-4)*cos(a) - z*sin(a) + 2.5
	end
	if x<-2 then
		local a= d*(t+7)
--		local xpx= round(x - 5*sin(7*d))
		return (x+4)*cos(a) - z*sin(a) + 2.5
	end
--	local a= t*d
	return x*cos(t*d) - z*sin(t*d) + 2.5
end

if y<-2 then
	if x>2 then
		local a= d*(t+3)
--		local xpx= round(x - 5*sin(3*d))
		return (x-4)*cos(a) - z*sin(a) + 2.5
