b = (z==-d and X and 1 or 0) * (yy==1 and 1 or 0)
c = (x==-d and Z and 1 or 0) * (yy==2 and 1 or 0)
d = (z==d and X and 1 or 0)  * (yy==3 and 1 or 0)
return (a+b+c+d)*15
"
