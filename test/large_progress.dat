or x<-10 and 0 -- empty far left
or x<-7 and GREY -- flagpole sitter
or y>0 -- flag
and z==round(sin(pi/2+x-t*pi/4)) and (
	flag_v<20 and ({WHITE,WHITE,PINK,LIGHTBLUE,BROWN,BLACK})[floor((flag_v+4)/4+1)] -- v
