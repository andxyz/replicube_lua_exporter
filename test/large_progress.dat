--Hmm I thought the planet ring was a slanted elipse. Took me a while to find the right math
-- It appears to be a slice of a particular circle? Or am I wrong?

-- early exits
if y<=-8 then return end
if y>=8 then
  -- comet trail
  if z<=0 and x>=7 and x+1==y then
    local comet_trail=x*x+(z+12)^2-196
    if comet_trail>=-28 and comet_trail<=0 then
      return ORANGE
    end
  end
  if x==6 and y==8 and z==0 then return GREY end
  return -- early exit
end

-- green planet
local X=x^2
local Z=z^2
local XZ=X+Z
local green_planet=XZ+y^2
if green_planet<=56 then
  return GREEN
end

local ring_slant=x-2*y
if ring_slant>=0 and ring_slant<=1 then
  local planet_ring=XZ-196
  if planet_ring>=-97 and planet_ring<=-54 then
    return DARKBROWN
  elseif planet_ring>=-54 and planet_ring<=0 then
    return BROWN
  end
end

-- pink moon
if y>=3 and x<=-8 then
  -- pink moon (perfect 3x3x3 cube)
  if y>=3 and y<=5 then
    if x>=-13 and x<=-11 and z>=11 and z<=13 then
      return PINK
    end
  end


  -- moon ring
--	local moon_ring=(x+12)^2+(z-12)^2
--  if y==4 and moon_ring>=9 and moon_ring<=16 then
--    return BROWN
--  end
	if y==4 then
    if z==12 and (x==-16 or x==-15 or x==-9 or x==-8) then
      return BROWN
    elseif (z==10 or z==11 or z==13 or z==14) and (x==-15 or x==-9) then
      return BROWN
    elseif (z==9 or z==15) and x>=-14 and x<=-10 then
      return BROWN
    elseif (z==8 or z==16) and x==-12 then
      return BROWN
    end
  end
	
	return
end

-- comet
if y>=6 and y<=8 then
--  if (x-6)^2+(y-7)^2+Z<=1 then
--    return GREY
--  end
  if x==6 and y==7 and (z==0 or z==1 or z==-1) then
    return GREY
  elseif x==6 and z==0 and (y==6 or y==8) then
    return GREY
  elseif y==7 and z==0 and (x==5 or x==7) then
    return GREY
  end
end

