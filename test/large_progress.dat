	return BLUE
end
--local theta= 0.4014257 -- Angle of inclination of Triton's orbit in radians
--print(\"cos_theta=\".. cos(theta) .. \" sin_theta=\" .. sin(theta))
--print(\"pi_12=\".. pi/12)
local cos_theta,sin_theta,pi_12= 0.92050486437677, 0.39073110275316, 0.26179938779915
local phi= t*pi_12

--Rotates point relative to the y-axis by phi
local px,py,pz= 8*cos(phi)-5*sin(phi), 0, 8*sin(phi) + 5*cos(phi)
--px,py,pz= px*cos(theta)-py*sin(theta), px*sin(theta)+py*cos(theta), pz -- z-axis by theta
--local in_triton= (x-px*cos_theta-py*sin_theta)^2 + (y-px*sin_theta+py*cos_theta)^2 + (z-pz)^2 <= 2
if (x-px*cos_theta-py*sin_theta)^2 + (y-px*sin_theta+py*cos_theta)^2 + (z-pz)^2 <= 2 then 
	return GREY
end
