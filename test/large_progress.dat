-- negative space
if x+y+z~=0 then return end
if x<-5 or z<-5 or y<-5 then return end
if x==-5 or z==-5 then return WHITE end
local n= 11-y
if x==-4 or z==-4 then return n-1 end
local cnk= 1
for k= 1,x+5 do
	cnk= cnk*(n-k)/k
end
return cnk

