"f2": "--233
--23.624

--Hmm I thought the planet ring was a slanted elipse. Took me a while to find the right math
-- It appears to be a slice of a particular circle? Or am I wrong?

-- green planet
local X=x*x
local XZ=X+z*z
local green_planet = XZ + y^2
local ring_slant = x - 2*y

-- START early exits
local comet_slant = x+1 - y
if y>7 and comet_slant<-1 then return end 
if ring_slant>=2 and green_planet>56 then return end
-- END early exits

-- finish green planet calcs
local planet_ring = XZ - 196 --14^2==196==2*98==4*49

-- pink moon
local X12,Z12=(x+12)^2,(z-12)^2
local is_p_moon = X12 + (y-4)^2 + Z12 <= 3
local moon_ring = X12 + Z12

-- comet
local is_comet = (x-6)^2 + (y-7)^2 + z*z <= 1
local comet_trail = X + (z+12)^2 - 196

-- render
if green_planet<=56 then
	return GREEN
elseif ring_slant>=0 and ring_slant<=1 then
	if planet_ring>=-97 and planet_ring<=-54 then
		return DARKBROWN
	elseif planet_ring>=-54 and planet_ring<=0 then
	  return BROWN
	end
elseif is_p_moon then
	return PINK
elseif y==4 and moon_ring>=9 and moon_ring<=16 then
	return BROWN
elseif is_comet then
	return GREY
elseif comet_slant==0 and	y>7 and comet_trail>=-28 and comet_trail<=0 then
	return ORANGE
end

