	return 
	(	
		(y==abs(x) or y==abs(z)) 
		and (y-1<abs(x) and y-1<abs(z)) 
		and abs(y)<=6
	)
	and ({4,8,9,14})[clamp(y+round((x*z)/34),1,4)]
end

t=3-t
return f(x/t,y,z/t)
"
},
