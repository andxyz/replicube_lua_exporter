"research1": "-- If it existed in reality,
-- it would be crispy as a croissant!

function spiralNr(xx, yy)
  local X = xx^2
  local Y = yy^2
  local m = max(X, Y)
   
	local se = (yy < xx) and 1 or 0
  local sw = (yy <= -xx) and 1 or 0
    
  local common = -2 * se + 4 * se * sw
	
  return 4 * m + (common - 1) * xx - (common + 1) * yy
end

return spiralNr(y,z)

